name = "ken-gei-prelude"
compatibility_date = "2024-09-02"
pages_build_output_dir = "dist"

# D1 Database
[[d1_databases]]
binding = "DB"
database_name = "ken-gei-prelude-db"
database_id = "<YOUR_D1_DATABASE_ID>"

# KV Namespace (cache + flyer images)
[[kv_namespaces]]
binding = "KV"
id = "<YOUR_KV_NAMESPACE_ID>"
